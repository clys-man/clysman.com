---
import { getLangFromUrl, useTranslations, getLocalizedPath } from "../i18n/utils";

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Remove current url path and remove trailing slash if exists
const currentUrlPath = Astro.url.pathname.replace(/\/+$/, "");

// Strip lang prefix to get bare path segments
const strippedPath =
  lang !== "pt_BR"
    ? currentUrlPath.replace(new RegExp(`^/${lang}`), "") || "/"
    : currentUrlPath;

// Get url array from path
// eg: /tags/tailwindcss => ['tags', 'tailwindcss']
const breadcrumbList = strippedPath.split("/").slice(1);

// if breadcrumb is Home > Posts > 1 <etc>
// replace Posts with Posts (page number)
if (breadcrumbList[0] === "posts") {
  breadcrumbList.splice(0, 2, `${t("nav.posts")} (${breadcrumbList[1] || 1})`);
}

// if breadcrumb is Home > Tags > [tag] > [page] <etc>
// replace [tag] > [page] with [tag] (page number)
if (breadcrumbList[0] === "tags" && !isNaN(Number(breadcrumbList[2]))) {
  breadcrumbList.splice(
    1,
    3,
    `${breadcrumbList[1]} ${Number(breadcrumbList[2]) === 1 ? "" : `(${breadcrumbList[2]})`}`
  );
}

// Translate known first-segment labels
const labelMap: Record<string, string> = {
  posts: t("nav.posts"),
  tags: t("nav.tags"),
  about: t("nav.about"),
  archives: t("nav.archives"),
  search: t("nav.search"),
};
---

<nav class="mx-auto mt-8 mb-1 w-full max-w-app px-4" aria-label="breadcrumb">
  <ul
    class="font-light [&>li]:inline [&>li:not(:last-child)>a]:hover:opacity-100"
  >
    <li>
      <a href={getLocalizedPath(lang, "/")} class="opacity-80">{t("breadcrumb.home")}</a>
      <span aria-hidden="true" class="opacity-80">&raquo;</span>
    </li>
    {
      breadcrumbList.map((breadcrumb, index) =>
        index + 1 === breadcrumbList.length ? (
          <li>
            <span
              class:list={["capitalize opacity-75", { lowercase: index > 0 }]}
              aria-current="page"
            >
              {/* Translate known labels, otherwise decode URI */}
              {labelMap[decodeURIComponent(breadcrumb).toLowerCase()] ??
                decodeURIComponent(breadcrumb)}
            </span>
          </li>
        ) : (
          <li>
            <a
              href={getLocalizedPath(lang, `/${breadcrumb}/`)}
              class="capitalize opacity-70"
            >
              {labelMap[decodeURIComponent(breadcrumb).toLowerCase()] ??
                breadcrumb}
            </a>
            <span aria-hidden="true">&raquo;</span>
          </li>
        )
      )
    }
  </ul>
</nav>
